<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.walker.mapper.CommentMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.walker.pojo.Comment">
        <id column="comment_id" property="commentId" />
        <result column="comment_content" property="commentContent" />
        <result column="comment_article_id" property="commentArticleId" />
        <result column="comment_user_id" property="commentUserId" />
        <result column="comment_time" property="commentTime" />
        <result column="enable" property="enable" />
        <result column="is_delete" property="isDelete" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        comment_id, comment_content, comment_article_id, comment_user_id, comment_time, enable, is_delete
    </sql>

    <!-- 批量查询各文章的评论数（含子回复） -->
    <select id="countByArticleIds" resultType="java.util.Map">
        SELECT articleId, COUNT(*) AS commentCount FROM (
            SELECT c.comment_article_id AS articleId
            FROM bbs_comment c
            WHERE c.comment_article_id IN
            <foreach collection="list" item="id" open="(" separator="," close=")">
                #{id}
            </foreach>
            AND c.is_delete = 0 AND c.enable = 1
            UNION ALL
            SELECT c2.comment_article_id AS articleId
            FROM bbs_reply r
            JOIN bbs_comment c2 ON r.comment_id = c2.comment_id
            WHERE c2.comment_article_id IN
            <foreach collection="list" item="id" open="(" separator="," close=")">
                #{id}
            </foreach>
            AND r.is_delete = 0 AND r.enable = 1
            AND c2.is_delete = 0
        ) t
        GROUP BY articleId
    </select>

</mapper>
