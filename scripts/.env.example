# ============================================
# BBS 部署环境变量配置
# 复制此文件为 .env 并修改其中的值
#   cp scripts/.env.example .env
# ============================================

# ---------- 数据库 ----------
# PostgreSQL 连接信息（容器部署或原生部署均适用）
# 容器部署时用容器名 bbs-postgres，原生部署时用 127.0.0.1
BBS_DB_HOST=bbs-postgres
BBS_DB_PORT=5432
BBS_DB_NAME=bbs
BBS_DB_USER=work_flow
BBS_DB_PASSWORD=your_password_here

# PostgreSQL 数据目录（原生部署时使用）
BBS_PG_DATA=/data/sql/postgre

# ---------- 后端 ----------
# Spring Boot 端口（必须与 application.yml 一致）
BBS_SERVER_PORT=9083

# 文件上传目录
BBS_UPLOAD_DIR=/data/bbs/bbsUpload

# 超级管理员密码（默认 1234@abcD）
BBS_SUPER_ADMIN_PASSWORD=1234@abcD

# ---------- Nginx / 前端 ----------
# Nginx 监听端口
NGINX_PORT=19848

# ---------- Podman / Docker ----------
# 容器网络名称
BBS_NET_NAME=bbs-net
# PostgreSQL 容器名（容器部署时使用）
BBS_PG_CONTAINER=bbs-postgres
# 后端容器名
BBS_SERVER_CONTAINER=bbs-server
# Nginx 容器名
BBS_NGINX_CONTAINER=bbs-nginx

# ---------- 镜像配置 ----------
# Docker/Podman 镜像仓库前缀（如需推送私有仓库）
IMAGE_PREFIX=
# 镜像标签
IMAGE_TAG=latest
